# =============================================================
# Holdings Report Agent — Environment Variables Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to git.
# =============================================================

# --- Upstox API ---
UPSTOX_CLIENT_ID=your_api_key_here
UPSTOX_CLIENT_SECRET=your_api_secret_here
UPSTOX_REDIRECT_URI=http://127.0.0.1

# --- Upstox Automated Login (for fully hands-free token refresh) ---
# Your Upstox registered mobile number (digits only, no +91)
UPSTOX_MOBILE=9999999999
# Your Upstox 4-6 digit PIN (same as app login PIN)
UPSTOX_PIN=123456
# Your TOTP base32 secret (from the QR code during 2FA setup)
# Run: python scripts/get_token.py --help  for instructions
UPSTOX_TOTP_SECRET=YOUR_BASE32_SECRET_HERE

# --- Google Gemini (LLM) ---
# Get free key at: https://aistudio.google.com
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Brave Search ---
# Get free key at: https://api.search.brave.com
BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# --- Gmail Delivery ---
# Your Gmail address (sends FROM this address)
GMAIL_ADDRESS=dones9798@gmail.com
# 16-character App Password from: https://myaccount.google.com/apppasswords
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
# Who receives the report (can be same as sender)
RECIPIENT_EMAIL=dones9798@gmail.com
